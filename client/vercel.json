{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://millionaire-sonter.amvera.io/api/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://millionaire-sonter.amvera.io/socket.io/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
